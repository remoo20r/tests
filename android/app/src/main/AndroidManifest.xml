<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Explicit INTERNET permission so a release build never depends on a
         plugin to pull it in. -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- TV support (Firestick / Android TV) without excluding phones:
         required="false" everywhere, so the same APK still installs on a
         phone that has a touchscreen and no leanback. Without the touchscreen
         entry a TV launcher can consider the app incompatible. -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false"/>
    <uses-feature
        android:name="android.software.leanback"
        android:required="false"/>

    <application
        android:label="Broken IPTV"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:banner="@drawable/tv_banner"
        android:logo="@drawable/tv_banner"
        android:allowBackup="false"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">
        <!-- banner: TV launchers (Fire TV in particular) show a RECTANGULAR
             320x180 artwork, not the square icon. With no banner declared the
             Firestick falls back to squeezing ic_launcher into that slot.
             Asset: res/drawable-xhdpi/tv_banner.png (+ xxhdpi for 4K sticks),
             generated from assets/icon/app_icon.png — see HANDOFF §5.
             It is declared BOTH here and on the activity on purpose: a launcher
             that reads ActivityInfo.banner directly (instead of loadBanner(),
             which falls back to the application one) gets 0 when it is only set
             here, and silently shows the square icon instead. -->
        <!-- allowBackup=false: Android Auto Backup would restore the Hive data
             (the saved playlist) on reinstall, but the Keystore key behind the
             secure-storage password is device-bound and NOT backed up, so the
             restored password became undecryptable → "Nessuna playlist attiva".
             Disabling backup makes uninstall a true clean slate. -->
        <!-- usesCleartextTraffic + networkSecurityConfig: many Xtream/M3U panels
             are served over plain HTTP. Android 9+ blocks cleartext by default,
             which is why the playlist didn't load on the phone. -->
        <!-- No screenOrientation lock: the app rotates freely; only the video
             player pins landscape (from Dart, see PlayerScreen). -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:icon="@mipmap/ic_launcher"
            android:banner="@drawable/tv_banner"
            android:logo="@drawable/tv_banner"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
                <!-- LEANBACK_LAUNCHER: makes TV launchers list the app as a
                     proper TV app (and use the banner above). Harmless on
                     phones, which keep using the LAUNCHER category. -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
